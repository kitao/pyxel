#!/usr/bin/env python3

from pathlib import Path

import pyxel

ROOT_DIR = Path(__file__).resolve().parent.parent
OUTPUT_DIR = ROOT_DIR / "wasm" / "images"

CROSS_ARM_WIDTH = 24
CROSS_ARM_LENGTH = 25
CROSS_MARGIN = 12
CROSS_AREA_X = 0
CROSS_AREA_WIDTH = CROSS_ARM_WIDTH + CROSS_ARM_LENGTH * 2 + CROSS_MARGIN * 2

MENU_WIDTH = 32
MENU_HEIGHT = 12
MENU_MARGIN = 7
MENU_AREA_WIDTH = MENU_WIDTH * 2 + MENU_MARGIN * 4
MENU_AREA_HEIGHT = MENU_HEIGHT + MENU_MARGIN * 2
MENU_AREA_X = CROSS_AREA_WIDTH + 1
MENU_AREA_Y = CROSS_AREA_WIDTH - MENU_AREA_HEIGHT

ACTION_WIDTH = 32
ACTION_MARGIN = 5
ACTION_INNER_GAP = 24
ACTION_X = ACTION_MARGIN + ACTION_WIDTH + (ACTION_INNER_GAP - ACTION_WIDTH) // 2
ACTION_AREA_X = MENU_AREA_X + MENU_AREA_WIDTH + 1
ACTION_AREA_WIDTH = ACTION_MARGIN * 2 + ACTION_WIDTH * 2 + ACTION_INNER_GAP

SCREEN_WIDTH = ACTION_AREA_X + ACTION_AREA_WIDTH
SCREEN_HEIGHT = CROSS_AREA_WIDTH


def draw_gamepad_cross(x, y, color):
    pyxel.camera(-x, -y)

    x1 = CROSS_MARGIN
    x2 = x1 + CROSS_ARM_LENGTH
    x3 = x2 + CROSS_ARM_WIDTH - 1
    x4 = x3 + CROSS_ARM_LENGTH

    # Cross is symmetric, reuse x coordinates as y
    y1 = x1
    y2 = x2
    y3 = x3
    y4 = x4

    pyxel.line(x2 + 2, y1, x3 - 2, y1, color)
    pyxel.line(x2 + 2, y4, x3 - 2, y4, color)
    pyxel.line(x1, y2 + 2, x1, y3 - 2, color)
    pyxel.line(x4, y2 + 2, x4, y3 - 2, color)

    pyxel.line(x1 + 2, y2, x2, y2, color)
    pyxel.line(x3, y2, x4 - 2, y2, color)
    pyxel.line(x1 + 2, y3, x2, y3, color)
    pyxel.line(x3, y3, x4 - 2, y3, color)

    pyxel.line(x2, y1 + 2, x2, y2, color)
    pyxel.line(x2, y3, x2, y4 - 2, color)
    pyxel.line(x3, y1 + 2, x3, y2, color)
    pyxel.line(x3, y3, x3, y4 - 2, color)

    pyxel.pset(x2 + 1, y1 + 1, color)
    pyxel.pset(x3 - 1, y1 + 1, color)
    pyxel.pset(x2 + 1, y4 - 1, color)
    pyxel.pset(x3 - 1, y4 - 1, color)
    pyxel.pset(x1 + 1, y2 + 1, color)
    pyxel.pset(x1 + 1, y3 - 1, color)
    pyxel.pset(x4 - 1, y2 + 1, color)
    pyxel.pset(x4 - 1, y3 - 1, color)

    pyxel.camera()


def draw_gamepad_menu(x, y, color):
    pyxel.camera(-x, -y)

    x1 = MENU_MARGIN
    x2 = x1 + MENU_WIDTH - 1
    x3 = x2 + MENU_MARGIN * 2 + 1
    x4 = x3 + MENU_WIDTH - 1

    y1 = MENU_MARGIN
    y2 = MENU_MARGIN + MENU_HEIGHT - 1

    pyxel.line(x1 + 2, y1, x2 - 2, y1, color)
    pyxel.line(x1 + 2, y2, x2 - 2, y2, color)
    pyxel.line(x1, y1 + 2, x1, y2 - 2, color)
    pyxel.line(x2, y1 + 2, x2, y2 - 2, color)

    pyxel.pset(x1 + 1, y1 + 1, color)
    pyxel.pset(x2 - 1, y1 + 1, color)
    pyxel.pset(x1 + 1, y2 - 1, color)
    pyxel.pset(x2 - 1, y2 - 1, color)

    pyxel.line(x3 + 2, y1, x4 - 2, y1, color)
    pyxel.line(x3 + 2, y2, x4 - 2, y2, color)
    pyxel.line(x3, y1 + 2, x3, y2 - 2, color)
    pyxel.line(x4, y1 + 2, x4, y2 - 2, color)

    pyxel.pset(x3 + 1, y1 + 1, color)
    pyxel.pset(x4 - 1, y1 + 1, color)
    pyxel.pset(x3 + 1, y2 - 1, color)
    pyxel.pset(x4 - 1, y2 - 1, color)

    pyxel.camera()


def draw_gamepad_button(x, y, color):
    pyxel.camera(-x, -y)

    x1 = ACTION_MARGIN
    x2 = ACTION_X
    x3 = x1 + ACTION_WIDTH + ACTION_INNER_GAP

    y1 = x1
    y2 = x2
    y3 = x3

    pyxel.ellib(x1, y2, ACTION_WIDTH, ACTION_WIDTH, color)
    pyxel.ellib(x3, y2, ACTION_WIDTH, ACTION_WIDTH, color)
    pyxel.ellib(x2, y1, ACTION_WIDTH, ACTION_WIDTH, color)
    pyxel.ellib(x2, y3, ACTION_WIDTH, ACTION_WIDTH, color)

    pyxel.camera()


class App:
    def __init__(self):
        pyxel.init(SCREEN_WIDTH, SCREEN_HEIGHT)
        self.show_guide = False
        pyxel.run(self.update, self.draw)

    def update(self):
        if pyxel.btnp(pyxel.KEY_ESCAPE):
            pyxel.quit()

        if pyxel.btnp(pyxel.KEY_SPACE):
            self.show_guide = not self.show_guide

        if pyxel.btnp(pyxel.KEY_RETURN):
            cross_image = pyxel.Image(CROSS_AREA_WIDTH, CROSS_AREA_WIDTH)
            cross_image.blt(
                0, 0, pyxel.screen, CROSS_AREA_X, 0, CROSS_AREA_WIDTH, CROSS_AREA_WIDTH
            )
            cross_image.save(
                str(
                    OUTPUT_DIR
                    / f"gamepad_cross_{CROSS_AREA_WIDTH}x{CROSS_AREA_WIDTH}.png"
                ),
                1,
            )

            menu_image = pyxel.Image(MENU_AREA_WIDTH, MENU_AREA_HEIGHT)
            menu_image.blt(
                0,
                0,
                pyxel.screen,
                MENU_AREA_X,
                MENU_AREA_Y,
                MENU_AREA_WIDTH,
                MENU_AREA_HEIGHT,
            )
            menu_image.save(
                str(
                    OUTPUT_DIR
                    / f"gamepad_menu_{MENU_AREA_WIDTH}x{MENU_AREA_HEIGHT}.png"
                ),
                1,
            )

            button_image = pyxel.Image(ACTION_AREA_WIDTH, ACTION_AREA_WIDTH)
            button_image.blt(
                0,
                0,
                pyxel.screen,
                ACTION_AREA_X,
                0,
                ACTION_AREA_WIDTH,
                ACTION_AREA_WIDTH,
            )
            button_image.save(
                str(
                    OUTPUT_DIR
                    / f"gamepad_button_{ACTION_AREA_WIDTH}x{ACTION_AREA_WIDTH}.png"
                ),
                1,
            )

    def draw(self):
        pyxel.cls(0)

        for i in range(-1, 2):
            for j in range(-1, 2):
                draw_gamepad_cross(CROSS_AREA_X + j, i, 1)
                draw_gamepad_menu(
                    MENU_AREA_X + j,
                    MENU_AREA_Y + i,
                    1,
                )
                draw_gamepad_button(ACTION_AREA_X + j, i, 1)

        draw_gamepad_cross(CROSS_AREA_X, 0, 12)
        draw_gamepad_menu(MENU_AREA_X, MENU_AREA_Y, 12)
        draw_gamepad_button(ACTION_AREA_X, 0, 12)

        pyxel.rect(MENU_AREA_X - 1, 0, 1, SCREEN_HEIGHT, 3)
        pyxel.rect(
            MENU_AREA_X,
            MENU_AREA_Y - 1,
            MENU_AREA_WIDTH,
            1,
            3,
        )
        pyxel.rect(ACTION_AREA_X - 1, 0, 1, SCREEN_HEIGHT, 3)

        if self.show_guide:
            pyxel.camera(-CROSS_AREA_X, 0)

            pyxel.rectb(
                0, CROSS_MARGIN + CROSS_ARM_LENGTH, CROSS_MARGIN, CROSS_ARM_WIDTH, 8
            )
            pyxel.rectb(
                CROSS_MARGIN + CROSS_ARM_LENGTH * 2 + CROSS_ARM_WIDTH,
                CROSS_MARGIN + CROSS_ARM_LENGTH,
                CROSS_MARGIN,
                CROSS_ARM_WIDTH,
                8,
            )
            pyxel.rectb(
                CROSS_MARGIN + CROSS_ARM_LENGTH, 0, CROSS_ARM_WIDTH, CROSS_MARGIN, 8
            )
            pyxel.rectb(
                CROSS_MARGIN + CROSS_ARM_LENGTH,
                CROSS_MARGIN + CROSS_ARM_LENGTH * 2 + CROSS_ARM_WIDTH,
                CROSS_ARM_WIDTH,
                CROSS_MARGIN,
                8,
            )

            pyxel.rectb(
                0,
                0,
                CROSS_MARGIN + CROSS_ARM_LENGTH,
                CROSS_MARGIN + CROSS_ARM_LENGTH,
                9,
            )
            pyxel.rectb(
                CROSS_MARGIN + CROSS_ARM_LENGTH + CROSS_ARM_WIDTH,
                0,
                CROSS_MARGIN + CROSS_ARM_LENGTH,
                CROSS_MARGIN + CROSS_ARM_LENGTH,
                9,
            )
            pyxel.rectb(
                0,
                CROSS_MARGIN + CROSS_ARM_LENGTH + CROSS_ARM_WIDTH,
                CROSS_MARGIN + CROSS_ARM_LENGTH,
                CROSS_MARGIN + CROSS_ARM_LENGTH,
                9,
            )
            pyxel.rectb(
                CROSS_MARGIN + CROSS_ARM_LENGTH + CROSS_ARM_WIDTH,
                CROSS_MARGIN + CROSS_ARM_LENGTH + CROSS_ARM_WIDTH,
                CROSS_MARGIN + CROSS_ARM_LENGTH,
                CROSS_MARGIN + CROSS_ARM_LENGTH,
                9,
            )

            pyxel.camera(-MENU_AREA_X, -MENU_AREA_Y)

            pyxel.rectb(0, MENU_MARGIN, MENU_MARGIN, MENU_HEIGHT, 8)
            pyxel.rectb(
                MENU_MARGIN + MENU_WIDTH, MENU_MARGIN, MENU_MARGIN, MENU_HEIGHT, 8
            )
            pyxel.rectb(MENU_MARGIN, 0, MENU_WIDTH, MENU_MARGIN, 8)
            pyxel.rectb(
                MENU_MARGIN, MENU_MARGIN + MENU_HEIGHT, MENU_WIDTH, MENU_MARGIN, 8
            )

            pyxel.rectb(
                MENU_MARGIN * 2 + MENU_WIDTH, MENU_MARGIN, MENU_MARGIN, MENU_HEIGHT, 8
            )
            pyxel.rectb(
                MENU_MARGIN * 3 + MENU_WIDTH * 2,
                MENU_MARGIN,
                MENU_MARGIN,
                MENU_HEIGHT,
                8,
            )
            pyxel.rectb(MENU_MARGIN * 3 + MENU_WIDTH, 0, MENU_WIDTH, MENU_MARGIN, 8)
            pyxel.rectb(
                MENU_MARGIN * 3 + MENU_WIDTH,
                MENU_MARGIN + MENU_HEIGHT,
                MENU_WIDTH,
                MENU_MARGIN,
                8,
            )

            pyxel.camera(-ACTION_AREA_X, 0)

            pyxel.rectb(0, ACTION_X, ACTION_MARGIN, ACTION_WIDTH, 8)
            pyxel.rectb(
                ACTION_MARGIN + ACTION_WIDTH * 2 + ACTION_INNER_GAP,
                ACTION_X,
                ACTION_MARGIN,
                ACTION_WIDTH,
                8,
            )
            pyxel.rectb(ACTION_X, 0, ACTION_WIDTH, ACTION_MARGIN, 8)
            pyxel.rectb(
                ACTION_X,
                ACTION_MARGIN + ACTION_WIDTH * 2 + ACTION_INNER_GAP,
                ACTION_WIDTH,
                ACTION_MARGIN,
                8,
            )

            pyxel.rectb(0, 0, ACTION_X, ACTION_X, 9)
            pyxel.rectb(ACTION_X + ACTION_WIDTH, 0, ACTION_X, ACTION_X, 9)
            pyxel.rectb(0, ACTION_X + ACTION_WIDTH, ACTION_X, ACTION_X, 9)
            pyxel.rectb(
                ACTION_X + ACTION_WIDTH, ACTION_X + ACTION_WIDTH, ACTION_X, ACTION_X, 9
            )

            pyxel.camera()


if __name__ == "__main__":
    App()
