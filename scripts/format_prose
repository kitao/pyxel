#!/usr/bin/env python3

# Apply each language's typographic conventions to translation and documentation
# text, so the prose stays uniform without manual review.

import json
from pathlib import Path
import re
import subprocess
import unicodedata

ROOT_DIR = Path(__file__).resolve().parent.parent

# Kana and kanji (the middle dot and full-width punctuation excluded) that take a
# half-width space against adjacent alphanumerics in Japanese and Chinese text.
_CJK = r"ぁ-ゖァ-ヺー一-鿿"

# Loanwords whose -er/-or/-ar origin takes a trailing long-vowel mark.
_LONG_VOWEL_WORDS = ("ブラウザ", "エディタ", "パラメータ")

# Spans whose interior is preserved verbatim while the span as a whole still
# takes a space against adjacent kana/kanji.
_SHORTCUT_SPAN = r"(?:Ctrl|Alt|Shift|Cmd)\([A-Za-z]+\)"
_PROTECTED_SPAN = re.compile(
    rf"{_SHORTCUT_SPAN}|`[^`]*`|\{{[^}}]*\}}|!?\[[^\]]*\][(（][^)）]*[)）]"
)
_PLACEHOLDER = ""
_PLACEHOLDER_RE = re.compile(_PLACEHOLDER)


def main():
    for path in _target_files():
        _format_file(path)


# File discovery and dispatch


def _target_files():
    listing = subprocess.run(
        ["git", "ls-files"], cwd=ROOT_DIR, capture_output=True, text=True, check=True
    ).stdout.splitlines()
    for rel in listing:
        if _is_target(rel):
            yield ROOT_DIR / rel


def _is_target(rel):
    if rel == "docs/coding-policy.md":
        # Keep policy examples literal; several intentionally show anti-patterns.
        return False
    if rel.startswith("web/") and rel.endswith(".json"):
        return True
    if rel.startswith(".github/") and rel.endswith(".yml"):
        return True
    return rel in ("docs/faq-ja.md", "README.md")


def _format_file(path):
    if path.suffix == ".json":
        _format_json(path)
    else:
        _format_lines(path, fenced=path.suffix == ".md")


def _format_json(path):
    raw = path.read_text(encoding="utf-8")
    replacements = []
    _collect_json_replacements(json.loads(raw), replacements)
    if replacements:
        path.write_text(_apply_json_replacements(raw, replacements), encoding="utf-8")


def _collect_json_replacements(node, replacements):
    if isinstance(node, dict):
        for key, value in node.items():
            if isinstance(value, str) and key in ("ja", "cn"):
                formatted = format_text(value, key)
                if formatted != value:
                    replacements.append((key, value, formatted))
            else:
                _collect_json_replacements(value, replacements)
    elif isinstance(node, list):
        for value in node:
            _collect_json_replacements(value, replacements)


def _apply_json_replacements(raw, replacements):
    parts = []
    cursor = 0
    for key, old, new in replacements:
        old_json = json.dumps(old, ensure_ascii=False)
        new_json = json.dumps(new, ensure_ascii=False)
        pattern = re.compile(rf'("{re.escape(key)}"\s*:\s*)({re.escape(old_json)})')
        match = pattern.search(raw, cursor)
        if match is None:
            raise RuntimeError(f"Failed to locate JSON value for '{key}'")
        parts.append(raw[cursor : match.start(2)])
        parts.append(new_json)
        cursor = match.end(2)
    parts.append(raw[cursor:])
    return "".join(parts)


def _format_lines(path, fenced):
    lines = path.read_text(encoding="utf-8").splitlines(keepends=True)
    in_fence = False
    changed = False
    for i, line in enumerate(lines):
        if fenced and line.lstrip().startswith("```"):
            in_fence = not in_fence
        elif not in_fence and re.search(rf"[{_CJK}]", line):
            indent = line[: len(line) - len(line.lstrip(" "))]
            formatted = indent + format_text(line[len(indent) :], "ja")
            if formatted != line:
                lines[i] = formatted
                changed = True
    if changed:
        path.write_text("".join(lines), encoding="utf-8")


# Per-string rules


def format_text(text, lang):
    spans = []
    text = _PROTECTED_SPAN.sub(lambda m: spans.append(m.group()) or _PLACEHOLDER, text)
    text = _normalize_common(text)
    if lang == "ja":
        text = _add_long_vowels(text)
    if lang in ("ja", "cn"):
        text = _normalize_parentheses(text, lang)
        text = _space_around_tokens(text)
        text = _remove_line_break_padding(text)
    span_iter = iter(spans)
    return _PLACEHOLDER_RE.sub(lambda m: next(span_iter), text)


# Language-agnostic rules


def _normalize_common(text):
    text = "".join(_halfwidth(char) for char in text)
    text = re.sub(r"[｡-ﾟ]+", lambda m: unicodedata.normalize("NFKC", m.group()), text)
    text = text.replace("　", " ")
    text = _remove_line_break_padding(text)
    return re.sub(r" {2,}", " ", text)


def _remove_line_break_padding(text):
    text = re.sub(r" *\n *", "\n", text)
    return re.sub(r"\\n +", r"\\n", text)


def _halfwidth(char):
    code = ord(char)
    if 0xFF10 <= code <= 0xFF19 or 0xFF21 <= code <= 0xFF3A or 0xFF41 <= code <= 0xFF5A:
        return chr(code - 0xFEE0)
    return char


# Japanese rules


def _add_long_vowels(text):
    for word in _LONG_VOWEL_WORDS:
        text = re.sub(word + r"(?!ー)", word + "ー", text)
    return text


# Japanese and Chinese rules


def _normalize_parentheses(text, lang):
    def repl(match):
        inner = match.group(1)
        if lang == "ja" and re.search(rf"[{_CJK}]", inner):
            return "（" + inner + "）"
        return "(" + inner + ")"

    text = re.sub(r"[（(]([^（）()]*)[）)]", repl, text)
    text = re.sub(r" *（ *", "（", text)
    text = re.sub(r" *） *", "）", text)
    edge = rf"{_CJK}0-9A-Za-z{_PLACEHOLDER}"
    text = re.sub(rf"([{edge}])\(", r"\1 (", text)
    text = re.sub(rf"\)([{edge}])", r") \1", text)
    return text


def _space_around_tokens(text):
    token = rf"0-9A-Za-z{_PLACEHOLDER}"
    text = re.sub(rf"([{_CJK}])([{token}])", r"\1 \2", text)
    return re.sub(rf"([{token}])([{_CJK}])", r"\1 \2", text)


if __name__ == "__main__":
    main()
