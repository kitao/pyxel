#!/usr/bin/env python3
"""Diagnose SDL2 video driver selection in installed pyxel wheel."""

import ctypes
import ctypes.util
import glob
import os
import sys


def find_bundled_sdl2():
    try:
        import pyxel
        pkg_dir = os.path.dirname(pyxel.__file__)
    except ImportError:
        print("ERROR: pyxel is not installed")
        sys.exit(1)
    parent = os.path.dirname(pkg_dir)
    for pattern in [
        os.path.join(pkg_dir, ".pyxel_lib", "libSDL2*.so*"),
        os.path.join(parent, "pyxel.libs", "libSDL2*.so*"),
    ]:
        matches = glob.glob(pattern)
        if matches:
            return matches[0]
    return ctypes.util.find_library("SDL2")


def test_driver(sdl2, label, env_val=None):
    if env_val:
        os.environ["SDL_VIDEODRIVER"] = env_val
    else:
        os.environ.pop("SDL_VIDEODRIVER", None)
    ret = sdl2.SDL_Init(0x20)  # SDL_INIT_VIDEO
    if ret >= 0:
        driver = sdl2.SDL_GetCurrentVideoDriver()
        print(f"  {label}: {driver.decode() if driver else '?'}")
        sdl2.SDL_Quit()
    else:
        err = sdl2.SDL_GetError()
        print(f"  {label}: FAILED ({err.decode() if err else '?'})")
        sdl2.SDL_Quit()


def main():
    print(f"WAYLAND_DISPLAY={os.environ.get('WAYLAND_DISPLAY', '(not set)')}")
    print(f"XDG_SESSION_TYPE={os.environ.get('XDG_SESSION_TYPE', '(not set)')}")

    sdl2_path = find_bundled_sdl2()
    if not sdl2_path:
        print("ERROR: SDL2 not found")
        sys.exit(1)
    print(f"SDL2: {sdl2_path}\n")

    sdl2 = ctypes.CDLL(sdl2_path)
    sdl2.SDL_Init.restype = ctypes.c_int
    sdl2.SDL_Init.argtypes = [ctypes.c_uint]
    sdl2.SDL_GetError.restype = ctypes.c_char_p
    sdl2.SDL_Quit.restype = None
    sdl2.SDL_GetCurrentVideoDriver.restype = ctypes.c_char_p

    test_driver(sdl2, "default    ")
    test_driver(sdl2, "wayland    ", "wayland")
    test_driver(sdl2, "x11        ", "x11")
    os.environ.pop("SDL_VIDEODRIVER", None)


if __name__ == "__main__":
    main()
