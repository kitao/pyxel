#!/usr/bin/env python3

import copy
import json
from pathlib import Path
import re

ROOT_DIR = Path(__file__).resolve().parent.parent
API_REF_JSON = ROOT_DIR / "web" / "api-reference" / "api-reference.json"
PYI_PATH = ROOT_DIR / "python" / "pyxel" / "__init__.pyi"

CLASS_CATEGORIES = {
    "image": "Image",
    "tilemap": "Tilemap",
    "sound": "Sound",
    "music": "Music",
    "channel": "Channel",
    "tone": "Tone",
    "font": "Font",
}


def localize(obj):
    if not obj:
        return ""
    if isinstance(obj, str):
        return obj
    return obj.get("en", "")


def _lowercase_first(s):
    return s[0].lower() + s[1:] if s else s


def _merge_items(existing, new):
    existing_desc = localize(existing.get("description"))
    new_desc = localize(new.get("description"))

    if new.get("params") and not existing.get("params"):
        merged = (
            f"{new_desc} Call without arguments to {_lowercase_first(existing_desc)}"
        )
        existing["params"] = new["params"]
    elif existing.get("params") and not new.get("params"):
        merged = (
            f"{existing_desc} Call without arguments to {_lowercase_first(new_desc)}"
        )
    else:
        merged = f"{existing_desc} {new_desc}"

    existing.setdefault("description", {})["en"] = merged


def _adapt_for_tilemap(item):
    desc = localize(item.get("description"))

    # blt-specific
    desc = desc.replace(
        "image bank img (0-2 or Image instance)",
        "tilemap tm (0-7 or Tilemap instance)",
    )
    desc = desc.replace("flips the image", "flips the tilemap")
    desc = desc.replace(
        "colkey sets the transparent color",
        "tilekey sets the transparent tile",
    )

    # General
    desc = desc.replace("the screen", "the tilemap")
    desc = desc.replace("full screen", "the full tilemap")

    # Color -> tile
    desc = desc.replace("a pixel of color col", "a tile")
    desc = desc.replace("a pixel with the color col", "a tile")
    desc = desc.replace("a string s in color col", "a string s with tile")
    desc = desc.replace("the same color as", "the same tile as")
    desc = desc.replace("color col", "tile")
    desc = desc.replace("and color col", "and tile")

    item.setdefault("description", {})["en"] = desc

    for p in item.get("params", []):
        if p["name"] == "col":
            p["name"] = "tile"
            p["description"] = {"en": "Tile (image_x, image_y)"}
        elif p["name"] == "colkey":
            p["name"] = "tilekey"
            p["description"] = {"en": "Transparent tile"}
        elif p["name"] == "img":
            p["name"] = "tm"
            p["description"] = {"en": "Tilemap number (0-7) or Tilemap instance"}


def _build_doc_map(api_data):
    doc_map = {}

    for category in api_data["categories"]:
        scope = CLASS_CATEGORIES.get(category["id"])

        for item in category.get("items", []):
            if not isinstance(item, dict) or "name" not in item:
                continue

            name = item["name"]
            if scope and "." in name:
                key = (scope, name.split(".", 1)[1])
            elif scope and name == scope:
                key = (scope, "__init__")
            else:
                key = (scope, name)

            if key in doc_map:
                _merge_items(doc_map[key], item)
            else:
                doc_map[key] = item

    return doc_map


def _fallback_item(class_name, func_name, doc_map):
    # Fall back to module-level graphics function for class drawing methods.
    # Image reuses the source as-is; Tilemap adapts descriptions.
    source = doc_map.get((None, func_name))
    if not source:
        return None
    if class_name == "Image":
        return source
    if class_name == "Tilemap":
        item = copy.deepcopy(source)
        _adapt_for_tilemap(item)
        return item
    return None


def _make_docstring(item, indent):
    desc = localize(item.get("description"))
    if not desc:
        return None

    params = item.get("params", [])
    param_lines = []
    for p in params:
        p_desc = localize(p.get("description"))
        if p_desc:
            param_lines.append(f"{indent}    {p['name']}: {p_desc}")

    ret_desc = localize(item.get("returns", {}).get("description"))
    notes = localize(item.get("notes"))
    examples = item.get("examples", [])

    if not param_lines and not ret_desc and not notes and not examples:
        return [f'{indent}"""{desc}"""']

    lines = [f'{indent}"""{desc}', ""]
    has_section = False

    if param_lines:
        lines.append(f"{indent}Args:")
        lines.extend(param_lines)
        has_section = True

    if ret_desc:
        if has_section:
            lines.append("")
        lines.append(f"{indent}Returns:")
        lines.append(f"{indent}    {ret_desc}")
        has_section = True

    if notes:
        if has_section:
            lines.append("")
        lines.append(f"{indent}Note:")
        lines.append(f"{indent}    {notes}")
        has_section = True

    if examples:
        if has_section:
            lines.append("")
        lines.append(f"{indent}Example::")
        for ex in examples:
            lines.append(f"{indent}    {ex}")

    lines.append(f'{indent}"""')
    return lines


def _strip_docstrings(content):
    lines = content.splitlines()
    result = []
    i = 0

    while i < len(lines):
        stripped = lines[i].strip()

        if stripped.startswith('"""'):
            if stripped.count('"""') >= 2:
                i += 1
            else:
                i += 1
                while i < len(lines) and '"""' not in lines[i]:
                    i += 1
                i += 1
            continue

        if stripped == "..." and result:
            prev = result[-1].rstrip()
            if prev.endswith(":"):
                result[-1] = prev + " ..."
                i += 1
                continue

        result.append(lines[i])
        i += 1

    return "\n".join(result) + "\n"


def _add_docstrings(content, doc_map):
    lines = content.splitlines(keepends=True)
    result = []
    current_class = None
    last_decorator = None
    i = 0

    while i < len(lines):
        line = lines[i]
        stripped = line.strip()

        # Track class scope
        cm = re.match(r"^class (\w+)", line)
        if cm:
            current_class = cm.group(1)
        elif (
            stripped
            and not line[0:1].isspace()
            and not stripped.startswith(("#", "@", "class "))
        ):
            current_class = None

        # Variable annotation (e.g. "width: int" or "    width: int")
        vm = re.match(r"^(\s*)(\w+)\s*:\s*\S+", line)
        if vm and not stripped.startswith(("def ", "class ")):
            var_indent = vm.group(1)
            var_name = vm.group(2)
            item = doc_map.get((current_class, var_name))
            if item:
                desc = localize(item.get("description"))
                if desc:
                    result.append(line)
                    result.append(f'{var_indent}"""{desc}"""\n')
                    i += 1
                    continue

        # Track decorators
        if stripped.startswith("@"):
            last_decorator = stripped

        # Start of def
        dm = re.match(r"^(\s*)def (\w+)\(", line)
        if dm:
            func_indent = dm.group(1)
            func_name = dm.group(2)
            body_indent = func_indent + "    "
            is_overload = last_decorator == "@overload"
            last_decorator = None

            # Collect full def signature (may span multiple lines)
            def_lines = []
            j = i
            while j < len(lines):
                def_lines.append(lines[j])
                if lines[j].rstrip().endswith(": ..."):
                    break
                j += 1
            j += 1

            if not is_overload:
                item = doc_map.get((current_class, func_name))
                if not item and current_class:
                    item = _fallback_item(current_class, func_name, doc_map)
                if item:
                    ds = _make_docstring(item, body_indent)
                    if ds:
                        last = def_lines[-1].rstrip()
                        def_lines[-1] = last[:-4] + "\n"  # remove ' ...'
                        result.extend(def_lines)
                        for dl in ds:
                            result.append(dl + "\n")
                        result.append(body_indent + "...\n")
                        i = j
                        continue

            result.extend(def_lines)
            i = j
            continue

        if not stripped.startswith("@"):
            last_decorator = None

        result.append(line)
        i += 1

    return "".join(result)


def generate_pyi_docstrings():
    api_data = json.loads(API_REF_JSON.read_text(encoding="utf-8"))
    doc_map = _build_doc_map(api_data)
    content = PYI_PATH.read_text(encoding="utf-8")
    content = _strip_docstrings(content)
    content = _add_docstrings(content, doc_map)
    PYI_PATH.write_text(content, encoding="utf-8")
    print(f"Generated {PYI_PATH.relative_to(ROOT_DIR)}")


if __name__ == "__main__":
    generate_pyi_docstrings()
