// Implicit f-string concatenation: f"a{x}" f"b{y}" -> f"a{x}b{y}"
// After TK_FSTR_END, if next token is TK_FSTR_BEGIN, continue parsing

@@@ FIND
        if(match(TK_FSTR_END)) {
            SequenceExpr* e = FStringExpr__new(line, count);
            for(int i = count - 1; i >= 0; i--) {
                e->items[i] = Ctx__s_popx(ctx());
            }
            Ctx__s_push(ctx(), (Expr*)e);
            return NULL;
@@@ REPLACE
