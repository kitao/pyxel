* text=auto

# Archives
*.whl binary
*.zip binary

# Audio
*.ogg binary

# Fonts
# BDF is a plain-text X11 font definition; keep LF so diffs stay readable across platforms.
*.bdf text eol=lf
*.ttf binary

# Images
*.gif binary
*.ico binary
*.jpeg binary
*.png binary

# Pyxel assets
*.pyxapp binary
# Pyxel palette is a plain-text INI-style file.
*.pyxpal text
*.pyxres binary
