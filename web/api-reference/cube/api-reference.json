  "categories": [
    {
      "id": "vec3",
      "title": {
        "en": "Vec3",
        "ja": "Vec3"
      },
      "items": [
        {
          "name": "Vec3",
          "type": "class",
          "signature": "Vec3(x, y, z)",
          "description": {
            "en": "A 3D vector with x, y, and z components.",
            "ja": "x・y・z 成分を持つ 3 次元ベクトル。"
          },
          "params": [
            {
              "name": "x",
              "type": "float",
              "description": {
                "en": "X component (default 0.0).",
                "ja": "x 成分（デフォルト 0.0）。"
              }
            },
            {
              "name": "y",
              "type": "float",
              "description": {
                "en": "Y component (default 0.0).",
                "ja": "y 成分（デフォルト 0.0）。"
              }
            },
            {
              "name": "z",
              "type": "float",
              "description": {
                "en": "Z component (default 0.0).",
                "ja": "z 成分（デフォルト 0.0）。"
              }
            }
          ],
          "examples": [
            "from pyxel.cube import Vec3",
            "v = Vec3(1.0, 2.0, 3.0)",
            "length = v.length()"
          ],
          "notes": {
            "en": "Import it from the pyxel.cube module.",
            "ja": "pyxel.cube モジュールからインポートして使う。"
          },
          "advanced": false
        },
        {
          "name": "x",
          "type": "variable",
          "signature": "x",
          "description": {
            "en": "The x component of the vector.",
            "ja": "ベクトルの x 成分。"
          },
          "value_type": "float",
          "advanced": false
        },
        {
          "name": "UP",
          "type": "constant",
          "signature": "Vec3.UP",
          "description": {
            "en": "Unit vector pointing up.",
            "ja": "上方向の単位ベクトル。"
          },
          "value_type": "Vec3",
          "advanced": false
        },
        {
          "name": "dot",
          "type": "function",
          "signature": "dot(other)",
          "description": {
            "en": "Return the dot product with another vector.",
            "ja": "別のベクトルとの内積を返す。"
          },
          "params": [
            {
              "name": "other",
              "type": "Vec3",
              "description": {
                "en": "The other vector.",
                "ja": "もう一方のベクトル。"
              }
            }
          ],
          "returns": {
            "type": "float",
            "description": {
              "en": "The dot product.",
              "ja": "内積。"
            }
          },
          "advanced": false
        },
        {
          "name": "cross",
          "type": "function",
          "signature": "cross(other)",
          "description": {
            "en": "Return the cross product with another vector.",
            "ja": "別のベクトルとの外積を返す。"
          },
          "params": [
            {
              "name": "other",
              "type": "Vec3",
              "description": {
                "en": "The other vector.",
                "ja": "もう一方のベクトル。"
              }
            }
          ],
          "returns": {
            "type": "Vec3",
            "description": {
              "en": "The cross product vector.",
              "ja": "外積ベクトル。"
            }
          },
          "advanced": false
        },
        {
          "name": "length",
          "type": "function",
          "signature": "length()",
          "description": {
            "en": "Return the length (magnitude) of the vector.",
            "ja": "ベクトルの長さ（大きさ）を返す。"
          },
          "returns": {
            "type": "float",
            "description": {
              "en": "The length of the vector.",
              "ja": "ベクトルの長さ。"
            }
          },
          "advanced": false
        },
        {
          "name": "normalize",
          "type": "function",
          "signature": "normalize()",
          "description": {
            "en": "Return a unit vector pointing in the same direction.",
            "ja": "同じ向きの単位ベクトルを返す。"
          },
          "returns": {
            "type": "Vec3",
            "description": {
              "en": "The normalized vector.",
              "ja": "正規化したベクトル。"
            }
          },
          "advanced": false
        },
        {
          "name": "lerp",
          "type": "function",
          "signature": "lerp(other, t)",
          "description": {
            "en": "Linearly interpolate toward another vector.",
            "ja": "別のベクトルへ線形補間する。"
          },
          "params": [
            {
              "name": "other",
              "type": "Vec3",
              "description": {
                "en": "The target vector.",
                "ja": "補間先のベクトル。"
              }
            },
            {
              "name": "t",
              "type": "float",
              "description": {
                "en": "Interpolation factor from 0.0 to 1.0.",
                "ja": "0.0〜1.0 の補間係数。"
              }
            }
          ],
          "returns": {
            "type": "Vec3",
            "description": {
              "en": "The interpolated vector.",
              "ja": "補間したベクトル。"
            }
          },
          "advanced": false
        }
      ]
    }
  ]
